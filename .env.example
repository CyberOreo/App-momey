# ────────────────────────────────────────────────────────────────────────────
# PolyBTC Trader — Environment Configuration Example
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="PolyBTC Trader"
ENVIRONMENT=development          # development | staging | production
PAPER_TRADING=true               # ALWAYS start with true; set false only for live
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/trading.log

# ── Polymarket CLOB API ───────────────────────────────────────────────────────
# Generate keys from https://polymarket.com/profile
# Private key must be the Ethereum private key for your Polygon wallet.
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_API_KEY=your-api-key-here
POLYMARKET_API_SECRET=your-api-secret-here
POLYMARKET_PASSPHRASE=your-passphrase-here
POLYMARKET_BASE_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CHAIN_ID=137          # 137 = Polygon mainnet

# ── Binance (public endpoints only — no key needed for market data) ───────────
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_REST_URL=https://api.binance.com/api/v3
BINANCE_API_KEY=                 # optional — only needed for account queries
BINANCE_API_SECRET=              # optional

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default — no setup required):
DATABASE_URL=sqlite+aiosqlite:///./data/trading.db
# PostgreSQL (for production / Docker):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/polybtc

# ── Telegram Bot Controller ───────────────────────────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy the token
# 2. Message your new bot, then open: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Find "chat":{"id": YOUR_CHAT_ID} and copy that number
# 3. Paste both below — bot activates automatically when the engine starts
TELEGRAM_BOT_TOKEN=              # e.g. 123456789:ABCdefGHI...
TELEGRAM_CHAT_ID=                # e.g. 123456789 (your personal chat id)
TELEGRAM_ENABLED=false           # legacy flag (token + chat_id is enough now)

# ── Capital ───────────────────────────────────────────────────────────────────
PAPER_BALANCE=1000.0             # starting paper balance in USDC

# ── Risk Limits ───────────────────────────────────────────────────────────────
MAX_RISK_PER_TRADE_PCT=0.02      # 2% of balance per trade
MAX_DAILY_DRAWDOWN_PCT=0.05      # halt trading after 5% daily loss
MAX_CONSECUTIVE_LOSSES=3         # 3 losses in a row → cooldown
COOLDOWN_MINUTES=60              # how long to pause after hitting loss streak
MAX_OPEN_POSITIONS=3             # maximum simultaneous open positions
MAX_TOTAL_EXPOSURE_PCT=0.20      # never deploy more than 20% of balance

# ── Execution Quality ─────────────────────────────────────────────────────────
MIN_CONFIDENCE_THRESHOLD=65.0    # signal score required to trade (0-100)
MIN_LIQUIDITY_USDC=500.0         # minimum order-book depth
MAX_SPREAD_PCT=0.08              # maximum bid/ask spread (8%)
MAX_SLIPPAGE_PCT=0.01            # maximum expected slippage (1%)
MIN_TIME_TO_RESOLUTION_HOURS=2.0 # don't trade markets resolving in <2h
MAX_TIME_TO_RESOLUTION_HOURS=168.0  # don't trade markets >1 week out

# ── Position Sizing ───────────────────────────────────────────────────────────
USE_KELLY=true                   # use fractional Kelly for sizing
KELLY_FRACTION=0.25              # quarter-Kelly (conservative)
MIN_POSITION_USDC=10.0           # minimum trade size in USDC
MAX_POSITION_USDC=200.0          # maximum trade size in USDC

# ── Strategy Parameters ───────────────────────────────────────────────────────
RSI_LONG_MIN=50.0                # minimum RSI for YES signals
RSI_LONG_MAX=70.0                # maximum RSI for YES signals
RSI_SHORT_MIN=30.0               # minimum RSI for NO signals
RSI_SHORT_MAX=50.0               # maximum RSI for NO signals
MIN_VOLUME_RATIO=1.2             # volume must be 1.2x the 20-bar MA
REQUIRE_VOLUME_CONFIRMATION=true # require volume to exceed MA before trading

# ── Sentiment (optional) ──────────────────────────────────────────────────────
CRYPTOPANIC_API_KEY=             # get free key at https://cryptopanic.com/developers/api/
SENTIMENT_ENABLED=false          # set true to enable sentiment signals

# ── Connection Resilience ─────────────────────────────────────────────────────
MAX_RECONNECT_ATTEMPTS=10
RECONNECT_BASE_DELAY=1.0         # seconds (doubles on each retry)
RECONNECT_MAX_DELAY=60.0         # cap at 60 seconds
